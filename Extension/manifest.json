{
  "manifest_version": 3,
  "name": "SOTI AI Analyser",
  "version": "2.4.7",
  "description": "Intelligent SOTI Log Analysis & Salesforce Integration",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "unlimitedStorage",
    "declarativeNetRequest",
    "downloads"
  ],
  "host_permissions": [
    "https://*.soti.net/*",
    "https://*.salesforce.com/*",
    "https://*.force.com/*",
    "https://api.allorigins.win/*",
    "https://api.codetabs.com/*",
    "https://ollama.com/*",
    "https://github.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/worker.min.js", "lib/*.wasm", "lib/*.gz"],
      "matches": [
        "https://*.soti.net/*",
        "https://*.salesforce.com/*",
        "https://*.force.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Open SOTI AI Analyser"
  },
  "side_panel": {
    "default_path": "SOTI_AI_Analyser.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.force.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
